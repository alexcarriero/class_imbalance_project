train_ctrl <- trainControl(method="repeatedcv", number=5, repeats=3, classProbs = T)
mod        <- train(outcome ~.,
data = df,
method = "svmLinear",
trControl = train_ctrl,
preProcess = c("center","scale"))
pred <- predict(mod, newdata = test, type = "prob")["one"]
colnames(pred) = NULL
# store results
pred <- cbind("ored" = pred, "iter" = iter, "class" = as.numeric(test$outcome) - 1)
return(pred)
}
do_svm(data[[i]], test[[i]], i)
